pipeline {
    agent any

    parameters {
        booleanParam(name: 'DEPLOY_K8S', defaultValue: true, description: 'Deploy image to Kubernetes after successful smoke test')
        string(name: 'KUBECONFIG_CREDENTIAL_ID', defaultValue: '', description: 'Optional Jenkins File credential ID for kubeconfig (leave empty to use agent default context)')
        string(name: 'K8S_CONTEXT', defaultValue: '', description: 'Optional kubectl context name to use before deploy')
    }

    environment {
        IMAGE_NAME = 'servpro-frontend'
        IMAGE_TAG = 'latest'
        CONTAINER_NAME = 'servpro-frontend-ci'
        K8S_NAMESPACE = 'servpro'
        K8S_DEPLOYMENT = 'frontend'
        K8S_CONTAINER = 'frontend'
    }

    stages {
        stage('Install Dependencies') {
            steps {
                echo 'Installing dependencies...'
                bat 'npm ci'
            }
        }

        stage('Build Frontend') {
            steps {
                echo 'Building frontend...'
                bat 'npm run build'
            }
        }

        stage('Build Docker Image') {
            steps {
                echo 'Building frontend image...'
                bat 'docker build -t %IMAGE_NAME%:%IMAGE_TAG% .'
            }
        }

        stage('Smoke Test Container') {
            steps {
                bat 'docker rm -f %CONTAINER_NAME% || ver > nul'
                bat 'docker run -d --name %CONTAINER_NAME% -p 5173:5173 %IMAGE_NAME%:%IMAGE_TAG%'
                powershell '''
                    $url = "http://localhost:5173"
                    $maxAttempts = 12
                    $delaySeconds = 5
                    $ready = $false

                    for ($i = 1; $i -le $maxAttempts; $i++) {
                        try {
                            $response = Invoke-WebRequest -Uri $url -UseBasicParsing -TimeoutSec 5
                            if ($response.StatusCode -ge 200 -and $response.StatusCode -lt 500) {
                                $ready = $true
                                Write-Host "Frontend is reachable on attempt $i with status $($response.StatusCode)."
                                break
                            }
                        } catch {
                            Write-Host "Attempt $i/$maxAttempts failed: $($_.Exception.Message)"
                        }

                        Start-Sleep -Seconds $delaySeconds
                    }

                    if (-not $ready) {
                        Write-Host "Frontend failed readiness check. Dumping container logs..."
                        docker logs ${env:CONTAINER_NAME}
                        throw "Frontend container is not reachable on $url"
                    }
                '''
            }
        }

        stage('Deploy To Kubernetes') {
            when {
                expression { params.DEPLOY_K8S }
            }
            steps {
                echo 'Deploying frontend image to Kubernetes...'
                script {
                    def runDeploy = {
                        powershell '''
                            $ErrorActionPreference = "Stop"

                            if ("${params.K8S_CONTEXT}" -ne "") {
                                kubectl config use-context "${params.K8S_CONTEXT}"
                            }

                            kubectl version --client
                            kubectl cluster-info
                            kubectl get namespace ${env.K8S_NAMESPACE}
                            kubectl set image deployment/${env.K8S_DEPLOYMENT} ${env.K8S_CONTAINER}=${env.IMAGE_NAME}:${env.IMAGE_TAG} -n ${env.K8S_NAMESPACE}
                            kubectl rollout restart deployment/${env.K8S_DEPLOYMENT} -n ${env.K8S_NAMESPACE}
                            kubectl rollout status deployment/${env.K8S_DEPLOYMENT} -n ${env.K8S_NAMESPACE} --timeout=180s
                        '''
                    }

                    if (params.KUBECONFIG_CREDENTIAL_ID?.trim()) {
                        withCredentials([file(credentialsId: params.KUBECONFIG_CREDENTIAL_ID.trim(), variable: 'KUBECONFIG_FILE')]) {
                            withEnv(["KUBECONFIG=${env.KUBECONFIG_FILE}"]) {
                                runDeploy()
                            }
                        }
                    } else {
                        runDeploy()
                    }
                }
            }
        }
    }

    post {
        always {
            bat 'docker rm -f %CONTAINER_NAME% || ver > nul'
        }
    }
}